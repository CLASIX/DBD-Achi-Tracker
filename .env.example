# DBD Achievement Tracker environment variables
#
# If your hosting platform reads this file and exposes these values as real
# environment variables to the Python process, NO app code changes are needed.
#
# If your platform does NOT auto-load .env files, use its dashboard/env-var UI
# instead, or ask for a python-dotenv update.

# Host binding
# For local Windows use:
# DBD_HOST=127.0.0.1
# DBD_PORT=5000
#
# For hosted platforms that provide PORT automatically, usually set only:
DBD_HOST=0.0.0.0

# Optional only if your host requires you to set the port yourself.
# Do NOT set this if your platform already injects PORT.
# DBD_PORT=5000

# Steam/profile caching
DBD_PROFILE_CACHE_TTL_SECONDS=900

# Basic rate limiting
DBD_RATE_LIMIT_MAX=30
DBD_RATE_LIMIT_WINDOW_SECONDS=60
