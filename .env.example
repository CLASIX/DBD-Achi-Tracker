# DBD Achievement Tracker environment variables
#
# If your hosting platform reads this file and exposes these values as real
# environment variables to the Python process, no app code changes are needed.

# Host binding
DBD_HOST=0.0.0.0

# Optional only if your host requires a manual app port.
# Do not set this if your platform already injects PORT.
# DBD_PORT=5000

# Steam/profile caching
DBD_PROFILE_CACHE_TTL_SECONDS=900

# Basic rate limiting
DBD_RATE_LIMIT_MAX=30
DBD_RATE_LIMIT_WINDOW_SECONDS=60

# Optional hosted protection
# If set, the site requires login.
# DBD_ACCESS_PASSWORD=change-this-password
# DBD_SECRET_KEY=change-this-secret-key

# Optional admin tools toggle
# Defaults to 1 when password protection is enabled, otherwise 0.
# DBD_ENABLE_ADMIN_TOOLS=1
